# Copy this file to .env.local and fill in the values from your Supabase project
# (Project settings → API → Project URL / anon public key).
# The anon key is meant to be public — real protection comes from the Row
# Level Security policies described in SUPABASE_SETUP.md.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
